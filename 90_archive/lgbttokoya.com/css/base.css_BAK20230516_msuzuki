/*親*/
.parent1				{
	width:80%;
	padding:0;
	position:relative;
	background-color: #DDC89A;
	border-radius: 10px;        /* CSS3草案 */
	-webkit-border-radius: 10px;    /* Safari,Google Chrome用 */
	-moz-border-radius: 10px;   /* Firefox用 */
}

/*子*/
.parent1 .child1			{
	background-color: #E0C9C2;
	position:relative;
	border-radius: 10px;        /* CSS3草案 */
	-webkit-border-radius: 10px;    /* Safari,Google Chrome用 */
	-moz-border-radius: 10px;   /* Firefox用 */
	/*テキストの補正*/
	color:#563F36;
	padding:10px 0;
	font-weight: bold;
	text-align: center;
}

/*擬似要素:after*/
.parent1 .child1:after	{
	content: ' ';
	width:0;
	height: 0;
	position:absolute;
	border:10px solid transparent;
	border-top-color:#E0C9C2;
	top:100%;
	left:50%;
}


